<div id="home" class="min-vh-100 py-3">
    <div class="container">
        <!-- Slim Hero Banner -->
        <div class="row mb-3">
            <div class="col-12">
                <div class="lsb-hero-banner position-relative overflow-hidden rounded-3 shadow-sm" style="max-height: 120px;">
                    <!-- Rotating Background -->
                    <div class="hero-bg-container position-absolute w-100 h-100" style="top: 0; left: 0;">
                        <img src="/app/public/images/lsb/lsb_wide_electric1.png" 
                             alt="Life.Science.Balance" 
                             class="hero-bg-image"
                             data-lsb-rotator="lsbWide"
                             data-lsb-rotator-dark="lsbDarkWide"
                             data-interval="15000">
                    </div>
                    <!-- Content Overlay -->
                    <div class="hero-content position-relative p-3" style="z-index: 2; display: flex; justify-content: space-between; align-items: center;">
                        <p class="lsb-welcome-text mb-0 small">
                            <i class="fas fa-bolt me-1"></i>Welcome back, {{ firstname }}
                        </p>
                        <div class="hero-quick-links d-flex gap-2">
                            <a href="/courses" class="btn btn-sm btn-glass" data-route-link>
                                <i class="fas fa-book-open me-1"></i>Courses
                            </a>
                            <a href="/stores" class="btn btn-sm btn-glass" data-route-link>
                                <i class="fas fa-shopping-bag me-1"></i>Store
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Stats Bar (Slim) -->
        <div class="stats-bar bg-steel-dark rounded-3 shadow-sm p-2 px-3 mb-3 d-flex flex-wrap justify-content-center align-items-center text-white gap-3">
            <div class="stat-item d-flex align-items-center py-1 px-2">
                <i class="fas fa-book me-2 text-steel-accent"></i>
                <span class="fw-bold me-1">{{stats.totalCourses}}</span>
                <span class="small opacity-75">Courses</span>
            </div>
            <div class="stat-item d-flex align-items-center py-1 px-2">
                <i class="fas fa-check-circle me-2 text-success"></i>
                <span class="fw-bold me-1">{{stats.completedModules}}</span>
                <span class="small opacity-75">Completed</span>
            </div>
            <div class="stat-item d-flex align-items-center py-1 px-2">
                <i class="fas fa-clock me-2 text-warning"></i>
                <span class="fw-bold me-1">{{stats.inProgress}}</span>
                <span class="small opacity-75">In Progress</span>
            </div>
            <div class="stat-item d-flex align-items-center py-1 px-2">
                <i class="fas fa-trophy me-2 text-info"></i>
                <span class="fw-bold me-1">{{stats.certificates}}</span>
                <span class="small opacity-75">Certificates</span>
            </div>
        </div>
        
        <div class="row g-4">
            <!-- Left Column: My Courses + My Stores -->
            <div class="col-lg-7">
                <!-- My Courses Section -->
                <div class="card mb-4">
                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-graduation-cap me-2"></i>My Courses</span>
                        {{#if hasCourses}}
                        <span class="badge bg-white text-success">{{ myCourses.length }}</span>
                        {{/if}}
                    </div>
                    <div class="card-body p-0">
                        {{#if hasCourses}}
                        <div class="list-group list-group-flush">
                            {{#each myCourses}}
                            <a href="/course/{{this.courseAlias}}" 
                               class="list-group-item list-group-item-action d-flex align-items-center py-3" data-route-link>
                                <div class="flex-shrink-0 me-3">
                                    {{#if this.imageUrl}}
                                    <img src="{{this.imageUrl}}" class="rounded" alt="{{this.name}}" style="width: 48px; height: 48px; object-fit: cover;">
                                    {{else}}
                                    <div class="bg-steel rounded d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                        <i class="fas fa-book text-white"></i>
                                    </div>
                                    {{/if}}
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-1 fw-bold">{{this.name}}</h6>
                                    {{#if this.progress}}
                                    <div class="progress" style="height: 4px;">
                                        <div class="progress-bar bg-success" style="width: {{this.progress}}%"></div>
                                    </div>
                                    <small class="text-muted">{{this.progress}}% complete</small>
                                    {{else}}
                                    <small class="text-muted">Continue learning</small>
                                    {{/if}}
                                </div>
                                <i class="fas fa-chevron-right text-muted"></i>
                            </a>
                            {{/each}}
                        </div>
                        <div class="p-3 text-center">
                            <a href="/courses" class="btn btn-outline-success btn-sm" data-route-link>
                                <i class="fas fa-list me-1"></i>View All
                            </a>
                        </div>
                        {{else}}
                        <div class="text-center py-4">
                            <i class="fas fa-folder-open fa-3x text-steel mb-3"></i>
                            <h6 class="fw-bold">No Courses Yet</h6>
                            <p class="text-steel small">Enroll in a course to get started</p>
                            <a href="/courses" class="btn btn-success" data-route-link>
                                <i class="fas fa-search me-2"></i>Browse
                            </a>
                        </div>
                        {{/if}}
                    </div>
                </div>

                <!-- My Stores Section -->
                <div class="card">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-shopping-bag me-2"></i>Stores</span>
                        {{#if hasStores}}
                        <span class="badge bg-white text-primary">{{ allStores.length }}</span>
                        {{/if}}
                    </div>
                    <div class="card-body p-0">
                        {{#if hasStores}}
                        <div class="list-group list-group-flush">
                            {{#each allStores}}
                            <a href="/store/{{this.storeAlias}}" 
                               class="list-group-item list-group-item-action d-flex align-items-center py-3" data-route-link>
                                <div class="flex-shrink-0 me-3">
                                    {{#if this.imageUrl}}
                                    <img src="{{this.imageUrl}}" class="rounded" alt="{{this.name}}" style="width: 48px; height: 48px; object-fit: cover;">
                                    {{else}}
                                    <div class="bg-steel rounded d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                        <i class="fas fa-store text-white"></i>
                                    </div>
                                    {{/if}}
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-1 fw-bold">{{this.name}}</h6>
                                    <small class="text-muted">{{#if this.description}}{{this.description}}{{else}}Browse store{{/if}}</small>
                                </div>
                                <i class="fas fa-chevron-right text-muted"></i>
                            </a>
                            {{/each}}
                        </div>
                        <div class="p-3 text-center">
                            <a href="/stores" class="btn btn-outline-primary btn-sm" data-route-link>
                                <i class="fas fa-store me-1"></i>All Stores
                            </a>
                        </div>
                        {{else}}
                        <div class="text-center py-4">
                            <i class="fas fa-store fa-3x text-steel mb-3"></i>
                            <h6 class="fw-bold">No Stores Available</h6>
                            <a href="/stores" class="btn btn-primary" data-route-link>
                                <i class="fas fa-search me-2"></i>Browse
                            </a>
                        </div>
                        {{/if}}
                    </div>
                </div>
            </div>
            
            <!-- Right Column: Featured Course + Ad -->
            <div class="col-lg-5">
                <div class="card mb-3">
                    <div class="card-header bg-steel text-white">
                        <i class="fas fa-star me-2"></i>Featured Course
                    </div>
                    <div class="card-body p-0">
                        {{#if featuredCourse}}
                        <div class="position-relative">
                            <img class="card-img-top" src="{{ featuredCourse.imageUrl }}" alt="{{ featuredCourse.title }}" style="height: 150px; object-fit: cover;">
                            <div class="card-img-overlay d-flex align-items-end" style="background: linear-gradient(transparent, rgba(44,62,80,0.9));">
                                <div class="text-white">
                                    <h6 class="card-title mb-1 fw-bold">{{ featuredCourse.title }}</h6>
                                </div>
                            </div>
                        </div>
                        <div class="p-3">
                            <p class="card-text text-steel small mb-2">{{ featuredCourse.description }}</p>
                            <a href="{{ featuredCourse.url }}" class="btn btn-primary btn-sm" data-route-link>
                                <i class="fas fa-arrow-right me-1"></i>View Course
                            </a>
                        </div>
                        {{else}}
                        <div class="p-3 text-center">
                            <i class="fas fa-book fa-2x text-steel mb-2"></i>
                            <h6 class="fw-bold">Explore Catalog</h6>
                            <p class="text-steel small mb-2">Browse available courses</p>
                            <a href="/store" class="btn btn-primary btn-sm" data-route-link>
                                <i class="fas fa-search me-1"></i>Browse
                            </a>
                        </div>
                        {{/if}}
                    </div>
                </div>
                
                <!-- Smaller Advertisement Section -->
                <div class="card">
                    <div class="card-header bg-steel-light py-1">
                        <small class="text-steel text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.05em;"><i class="fas fa-bullhorn me-1"></i>Sponsored</small>
                    </div>
                    <div class="card-body p-2">
                        {{#if ad.adsense.enabled}}
                        <!-- Google AdSense -->
                        <ins class="adsbygoogle"
                             style="display:block"
                             data-ad-client="{{ ad.adsense.publisherId }}"
                             data-ad-slot="{{ ad.adsense.adSlot }}"
                             data-ad-format="{{ ad.adsense.adFormat }}"
                             data-full-width-responsive="{{ ad.adsense.fullWidthResponsive }}"></ins>
                        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
                        {{else}}
                        <!-- House Ad / Fallback -->
                        <div class="d-flex align-items-center">
                            <div class="flex-grow-1">
                                <h6 class="fw-bold mb-1 small">{{ ad.title }}</h6>
                                <p class="text-steel small mb-0" style="font-size: 0.75rem;">{{ ad.description }}</p>
                            </div>
                            <button class="btn btn-outline-primary btn-sm ms-2" data-bs-toggle="modal" data-bs-target="#courseCreatorModal">
                                <i class="fas fa-arrow-right"></i>
                            </button>
                        </div>
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Course Creator Modal -->
<div class="modal fade" id="courseCreatorModal" tabindex="-1" aria-labelledby="courseCreatorModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="courseCreatorModalLabel">
                    <i class="fas fa-plus-circle me-2"></i>Become a Course Creator
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3">Share your expertise! Submit a course request and we'll review it within 24-48 hours.</p>
                <form id="courseCreatorForm">
                    <div class="mb-3">
                        <label for="courseName" class="form-label">Course Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="courseName" required placeholder="e.g., Introduction to Web Development">
                    </div>
                    <div class="mb-3">
                        <label for="courseDescription" class="form-label">Brief Description <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="courseDescription" rows="3" required placeholder="Describe what students will learn..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="courseCategory" class="form-label">Category</label>
                        <select class="form-select" id="courseCategory">
                            <option value="General">General</option>
                            <option value="Technology">Technology</option>
                            <option value="Business">Business</option>
                            <option value="Health">Health & Wellness</option>
                            <option value="Arts">Arts & Creativity</option>
                            <option value="Science">Science</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div id="courseCreatorMessage" class="alert d-none" role="alert"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="submitCourseRequest">
                    <i class="fas fa-paper-plane me-2"></i>Submit Request
                </button>
            </div>
        </div>
    </div>
</div>
